{
  "name": "eslint-plugin-scope-boundaries",
  "version": "0.2.0",
  "description": "ESLint plugin for Nx monorepos that enforces scope-based import boundaries, with configurable cross-scope exceptions and ignored target scopes.",
  "license": "MIT",
  "keywords": [
    "eslint",
    "eslintplugin",
    "nx",
    "boundaries",
    "monorepo"
  ],
  "main": "index.js",
  "exports": {
    ".": "./index.js"
  },
  "files": [
    "index.js",
    "rules",
    "lib",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18.18"
  },
  "scripts": {
    "test": "node --test test/*.test.js",
    "check": "npm run test"
  },
  "peerDependencies": {
    "@nx/devkit": "^22.0.0",
    "@nx/eslint-plugin": "^22.0.0",
    "@typescript-eslint/utils": "^8.0.0",
    "eslint": "^8.57.0 || ^9.0.0",
    "nx": "^22.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/michalwlodarczyk/eslint-plugin-scope-boundaries.git"
  },
  "bugs": {
    "url": "https://github.com/michalwlodarczyk/eslint-plugin-scope-boundaries/issues"
  },
  "homepage": "https://github.com/michalwlodarczyk/eslint-plugin-scope-boundaries#readme",
  "publishConfig": {
    "access": "public"
  }
}
